{
  "name": "@tdwhere/do-it",
  "version": "0.7.3",
  "description": "Installable AI coding workflow for Codex and Claude Code with risk-based routing, scoped sub-agents, and evidence-backed completion.",
  "type": "module",
  "license": "MIT",
  "author": "tdwhere123",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tdwhere123/do-it.git"
  },
  "bugs": {
    "url": "https://github.com/tdwhere123/do-it/issues"
  },
  "homepage": "https://github.com/tdwhere123/do-it#readme",
  "keywords": [
    "agentic-workflow",
    "ai-agents",
    "codex-cli",
    "codex",
    "do-it",
    "workflow",
    "skills",
    "agents",
    "subagents",
    "developer-tools"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    ".agents/plugins/",
    ".claude-plugin/",
    "agents/",
    "bin/",
    "commands/",
    "dist/claude/",
    "docs/",
    "hooks/",
    "install/",
    "manifest.json",
    "plugins/do-it/",
    "README.zh-CN.md",
    "scripts/",
    "skills/custom/README.md",
    "skills/do-it/"
  ],
  "bin": {
    "do-it": "bin/do-it.mjs"
  },
  "scripts": {
    "setup": "node bin/do-it.mjs setup",
    "install:do-it": "node install/manage.mjs install",
    "install:claude": "node install/manage.mjs install --target=claude",
    "doctor": "node install/manage.mjs doctor",
    "doctor:claude": "node install/manage.mjs doctor --target=claude",
    "validate:agents": "node scripts/validate-agent-bundle.mjs",
    "build:generated": "node scripts/build-claude-agents.mjs && node scripts/build-skills-index.mjs",
    "build:claude-agents": "npm run build:generated && node scripts/validate-agent-bundle.mjs",
    "build:codex-plugin": "npm run build:generated && node scripts/build-codex-plugin.mjs && node scripts/validate-agent-bundle.mjs",
    "prepack": "npm run build:generated && node scripts/build-codex-plugin.mjs && node scripts/validate-agent-bundle.mjs",
    "do-it": "node bin/do-it.mjs",
    "lint": "bash scripts/lint-hooks.sh",
    "lint-hooks": "bash scripts/lint-hooks.sh",
    "test-hooks": "bash scripts/test-hooks.sh && bash tests/hooks/router.test.sh",
    "test": "npm run build:generated && npm run validate:agents && npm run lint-hooks && npm run test-hooks"
  },
  "engines": {
    "node": ">=18"
  }
}
